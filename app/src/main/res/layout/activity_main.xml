<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎙️ Intercom Moto"
            android:textColor="@color/teal"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Escolha a sua função:"
            android:textColor="@color/text_light"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"/>

        <!-- SELEÇÃO -->
        <LinearLayout
            android:id="@+id/layoutSelecao"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <Button
                android:id="@+id/btnMotorista"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:text="🏍️ Sou o Motorista"
                android:textColor="@color/teal"
                android:textStyle="bold"
                android:textSize="18sp"
                android:backgroundTint="@color/btn_dark"/>

            <Button
                android:id="@+id/btnPassageiro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🎒 Sou o Passageiro"
                android:textColor="@color/pink"
                android:textStyle="bold"
                android:textSize="18sp"
                android:backgroundTint="@color/btn_dark"/>
        </LinearLayout>

        <!-- PAINEL MOTORISTA -->
        <LinearLayout
            android:id="@+id/layoutMotorista"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:visibility="gone"
            android:background="@color/panel_dark"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mãos no guidão! Diga bem alto:"
                android:textColor="@color/text_light"
                android:textSize="16sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&quot;AVISO&quot;"
                android:textColor="@color/pink"
                android:textSize="30sp"
                android:textStyle="bold"
                android:layout_marginVertical="8dp"/>

            <Button
                android:id="@+id/btnTalk"
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:text="LIGAR\nSENTINELA"
                android:textColor="@color/text_gray"
                android:textStyle="bold"
                android:background="@drawable/circle_button"
                android:layout_marginTop="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ele só dará um BIPE quando escutar &quot;AVISO&quot;."
                android:textColor="@color/text_gray"
                android:textSize="13sp"
                android:layout_marginTop="16dp"
                android:gravity="center"/>

            <TextView
                android:id="@+id/debugLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🎤 Aguardando ativação..."
                android:textColor="@color/text_gray"
                android:textSize="12sp"
                android:background="#1A1A2E"
                android:padding="10dp"
                android:layout_marginTop="12dp"/>
        </LinearLayout>

        <!-- PAINEL PASSAGEIRO -->
        <LinearLayout
            android:id="@+id/layoutPassageiro"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:background="@color/panel_dark"
            android:padding="16dp">

            <TextView
                android:id="@+id/chatText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="60dp"
                android:text="Aguardando o piloto..."
                android:textColor="@color/teal"
                android:textSize="22sp"
                android:textStyle="bold"
                android:background="@color/btn_dark"
                android:padding="14dp"
                android:layout_marginBottom="10dp"/>

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2">

                <Button android:id="@+id/btnCuidado" style="@style/FastBtn" android:text="⚠️ CUIDADO!" android:textColor="@color/pink"/>
                <Button android:id="@+id/btnDevagar" style="@style/FastBtn" android:text="🛑 VAI DEVAGAR"/>
                <Button android:id="@+id/btnParar" style="@style/FastBtn" android:text="🏍️ PARA A MOTO"/>
                <Button android:id="@+id/btnBanheiro" style="@style/FastBtn" android:text="🚾 BANHO"/>
                <Button android:id="@+id/btnPosto" style="@style/FastBtn" android:text="⛽ POSTO"/>
                <Button android:id="@+id/btnOk" style="@style/FastBtn" android:text="👍 TUDO CERTO"/>
            </GridLayout>

            <EditText
                android:id="@+id/txtMensagem"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Ou digite outra mensagem..."
                android:textColorHint="@color/text_gray"
                android:textColor="@color/text_light"
                android:background="@color/btn_dark"
                android:padding="14dp"
                android:layout_marginTop="16dp"/>

            <Button
                android:id="@+id/btnEnviar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📩 Enviar Texto Livre"
                android:textColor="@color/white"
                android:backgroundTint="@color/teal"
                android:layout_marginTop="10dp"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
